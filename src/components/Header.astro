---
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import ThemeToggle from "@components/ThemeToggle.astro";
import { SITE } from "@consts";
---

<header>
  <!-- gradient: strong at top, fades to transparent at bottom -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: linear-gradient(to bottom, var(--header-bg-start) 0%, var(--header-bg-mid) 55%, transparent 100%);"
  ></div>
  <Container>
    <div class="relative flex flex-wrap gap-y-2 justify-between items-center -mx-1">
      <Link href="/" underline={false}>
        <div class="font-semibold px-3 py-1 rounded-full bg-black/5 dark:bg-white/10 backdrop-blur-sm text-black dark:text-white">
          {SITE.NAME}
        </div>
      </Link>
      <nav class="flex gap-1 items-center px-3 py-1 rounded-full bg-black/5 dark:bg-white/10 backdrop-blur-sm">
        <Link href="/post">
          post
        </Link>
        <span>
          {`/`}
        </span>
        <Link href="/show">
          show
        </Link>
        <span>
          {`/`}
        </span>
        <Link href="/snowball">
          snowball
        </Link>
        <span class="mx-1">·</span>
        <ThemeToggle iconOnly />
      </nav>
    </div>
  </Container>
</header>

<style>
  :root {
    --header-bg-start: #eeece1;
    --header-bg-mid: rgba(238, 236, 225, 0.7);
  }
  :global(html.dark) {
    --header-bg-start: #000000;
    --header-bg-mid: rgba(0, 0, 0, 0.55);
  }
</style>
