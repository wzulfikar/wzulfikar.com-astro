---
interface Props {
  images?: { src: string; alt?: string }[];
}

const { images } = Astro.props;
---

{images && images.length > 0 && (
  <div class="lb-images">
    {images.map(img => (
      <img src={img.src} alt={img.alt ?? ''} data-lightbox />
    ))}
  </div>
)}

<div id="img-lightbox" aria-modal="true" role="dialog">
  <img id="img-lightbox-img" src="" alt="" />
</div>

<style>
  .lb-images {
    display: flex;
    flex-direction: row;
    justify-content: flex-start;
    gap: 1rem;
    overflow-x: auto;
  }
  .lb-images img {
    max-height: 300px;
    width: auto;
    flex-shrink: 0;
    border-radius: 0.375rem;
    cursor: zoom-in;
    margin: 0;
  }

  :global(article p:has(img)) {
    display: flex;
    flex-direction: row;
    justify-content: flex-start;
    gap: 1rem;
    overflow-x: auto;
    padding-bottom: 0.25rem;
    margin-bottom: 0.5rem;
  }
  :global(article p:has(img) img) {
    max-height: 300px;
    width: auto;
    flex-shrink: 0;
    border-radius: 0.375rem;
    cursor: zoom-in;
    margin: 0;
  }

  #img-lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0,0,0,0.85);
    align-items: center;
    justify-content: center;
    cursor: zoom-out;
  }
  #img-lightbox.open {
    display: flex;
    animation: lb-backdrop-in 0.2s ease;
  }
  #img-lightbox.closing {
    display: flex;
    animation: lb-backdrop-out 0.18s ease forwards;
  }
  #img-lightbox.open img {
    animation: lb-img-in 0.2s ease;
  }
  #img-lightbox.closing img {
    animation: lb-img-out 0.18s ease forwards;
  }
  #img-lightbox img {
    max-width: 92vw;
    max-height: 92vh;
    border-radius: 0.5rem;
    object-fit: contain;
    box-shadow: 0 8px 40px rgba(0,0,0,0.5);
  }

  @keyframes lb-backdrop-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes lb-backdrop-out {
    from { opacity: 1; }
    to { opacity: 0; }
  }
  @keyframes lb-img-in {
    from { opacity: 0; transform: scale(0.93); }
    to { opacity: 1; transform: scale(1); }
  }
  @keyframes lb-img-out {
    from { opacity: 1; transform: scale(1); }
    to { opacity: 0; transform: scale(0.93); }
  }
</style>

<script>
  const lightbox = document.getElementById('img-lightbox')!;
  const lbImg = document.getElementById('img-lightbox-img') as HTMLImageElement;

  function openLightbox(img: HTMLImageElement) {
    lbImg.src = img.src;
    lbImg.alt = img.alt;
    lightbox.classList.add('open');
  }

  document.querySelectorAll('article p img').forEach(img => {
    (img as HTMLElement).addEventListener('click', () => openLightbox(img as HTMLImageElement));
  });

  document.querySelectorAll<HTMLImageElement>('[data-lightbox]').forEach(img => {
    img.addEventListener('click', () => openLightbox(img));
  });

  function closeLightbox() {
    lightbox.classList.replace('open', 'closing');
    lightbox.addEventListener('animationend', () => {
      lightbox.classList.remove('closing');
    }, { once: true });
  }

  lightbox.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>
