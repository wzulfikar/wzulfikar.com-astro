---
import { getCollection } from "astro:content";
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import ArrowCard from "@components/ArrowCard.astro";
import Link from "@components/Link.astro";
import { SITE, HOME, SOCIALS } from "@consts";

const allBlog = (await getCollection("post"))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const blog = allBlog.slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);

const allShow = (await getCollection("show"))
  .filter(entry => !entry.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const show = allShow.slice(0, SITE.NUM_SHOWS_ON_HOMEPAGE);

const allSnowball = (await getCollection("snowball"))
  .filter(entry => !entry.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const snowball = allSnowball.slice(0, SITE.NUM_SNOWBALLS_ON_HOMEPAGE);
---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <h4 class="animate font-semibold text-black dark:text-white">
      Hi, I'm Wildan <span class="text-xl">👋</span>
    </h4>
    <div class="space-y-16">
      <section>
        <article class="space-y-4">
          <p class="animate">
            Software engineer and maker. I write about things I think about, show what I build,
            and document patterns worth keeping.
          </p>
        </article>
      </section>

      <section class="animate space-y-6">
        <div>
          <h5 class="font-semibold text-black dark:text-white">
            Post
          </h5>
        </div>
        <ul class="flex flex-col gap-4">
          {blog.map(post => (
            <li>
              <ArrowCard entry={post} />
            </li>
          ))}
        </ul>
        {allBlog.length > SITE.NUM_POSTS_ON_HOMEPAGE && (
          <div class="flex justify-start">
            <Link href="/blog">See all posts</Link>
          </div>
        )}
      </section>

      <section class="animate space-y-6">
        <div>
          <h5 class="font-semibold text-black dark:text-white">
            Show
          </h5>
          <p class="text-sm text-black/80 dark:text-white/80 mt-1">Things I'm working on.</p>
        </div>
        <ul class="flex flex-col gap-4">
          {show.map(entry => (
            <li>
              <ArrowCard entry={entry} />
            </li>
          ))}
        </ul>
        {allShow.length > SITE.NUM_SHOWS_ON_HOMEPAGE && (
          <div class="flex justify-start">
            <Link href="/show">See all</Link>
          </div>
        )}
      </section>

      <section class="animate space-y-6">
        <div>
          <h5 class="font-semibold text-black dark:text-white">
            Snowball
          </h5>
          <p class="text-sm text-black/80 dark:text-white/80 mt-1">Patterns worth investing in. Compounding and transferable.</p>
        </div>
        <ul class="flex flex-col gap-4">
          {snowball.map(entry => (
            <li>
              <ArrowCard entry={entry} />
            </li>
          ))}
        </ul>
        {allSnowball.length > SITE.NUM_SNOWBALLS_ON_HOMEPAGE && (
          <div class="flex justify-start">
            <Link href="/snowball">See all</Link>
          </div>
        )}
      </section>

      <section class="animate space-y-4">
        <h5 class="font-semibold text-black dark:text-white">
          Let's Connect
        </h5>
        <article>
          <p>
            If you want to get in touch with me about something or just to say hi,
            reach out on social media.
          </p>
        </article>
        <ul class="flex flex-wrap gap-2">
          {SOCIALS.map((SOCIAL, i) => (
            <li class="flex gap-x-2 text-nowrap">
              <Link href={SOCIAL.HREF} external aria-label={`${SITE.NAME} on ${SOCIAL.NAME}`}>
                {SOCIAL.NAME}
              </Link>
              {i < SOCIALS.length - 1 ? "/":""}
            </li>
          ))}
        </ul>
      </section>
    </div>
  </Container>
</PageLayout>
