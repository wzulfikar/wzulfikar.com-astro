---
import { getCollection } from "astro:content";
import ArrowCard from "@components/ArrowCard.astro";
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import { HOME, SITE, SOCIALS } from "@consts";
import PageLayout from "@layouts/PageLayout.astro";

const allBlog = (await getCollection("post"))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allShow = (await getCollection("show"))
	.filter((entry) => !entry.data.draft)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allSnowball = (await getCollection("snowball"))
	.filter((entry) => !entry.data.draft)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <h4 class="animate font-semibold text-black dark:text-white">
      Hi, I'm Wildan <span class="text-xl">👋</span>
    </h4>
    <div class="space-y-16">
      <section>
        <article class="space-y-4">
          <p class="animate">
            Software engineer and maker. I write about things I think about, show what I build,
            and document patterns worth keeping.
          </p>
        </article>
      </section>

      <section class="animate space-y-6">
        <div>
          <h5 class="font-semibold text-black dark:text-white">
            Post
          </h5>
        </div>
        <ul class="flex flex-col gap-4" data-future-filter data-limit={SITE.NUM_POSTS_ON_HOMEPAGE} data-see-all="blog-see-all">
          {allBlog.map(post => (
            <li data-date={post.data.date.toISOString()}>
              <ArrowCard entry={post} />
            </li>
          ))}
        </ul>
        <div id="blog-see-all" class="flex justify-start" hidden>
          <Link href="/post">See all posts</Link>
        </div>
      </section>

      <section class="animate space-y-6">
        <div>
          <h5 class="font-semibold text-black dark:text-white">
            Show
          </h5>
          <p class="text-sm text-black/80 dark:text-white/80 mt-1">Things I'm working on.</p>
        </div>
        <ul class="flex flex-col gap-4" data-future-filter data-limit={SITE.NUM_SHOWS_ON_HOMEPAGE} data-see-all="show-see-all">
          {allShow.map(entry => (
            <li data-date={entry.data.date.toISOString()}>
              <ArrowCard entry={entry} />
            </li>
          ))}
        </ul>
        <div id="show-see-all" class="flex justify-start" hidden>
          <Link href="/show">See all</Link>
        </div>
      </section>

      <section class="animate space-y-6">
        <div>
          <h5 class="font-semibold text-black dark:text-white">
            Snowball
          </h5>
          <p class="text-sm text-black/80 dark:text-white/80 mt-1">Patterns worth investing in. Compounding and transferable.</p>
        </div>
        <ul class="flex flex-col gap-4" data-future-filter data-limit={SITE.NUM_SNOWBALLS_ON_HOMEPAGE} data-see-all="snowball-see-all">
          {allSnowball.map(entry => (
            <li data-date={entry.data.date.toISOString()}>
              <ArrowCard entry={entry} />
            </li>
          ))}
        </ul>
        <div id="snowball-see-all" class="flex justify-start" hidden>
          <Link href="/snowball">See all</Link>
        </div>
      </section>

      <section class="animate space-y-4">
        <h5 class="font-semibold text-black dark:text-white">
          Let's Connect
        </h5>
        <article>
          <p>
            If you want to get in touch with me about something or just to say hi,
            reach out on social media.
          </p>
        </article>
        <ul class="flex flex-wrap gap-2">
          {SOCIALS.map((SOCIAL, i) => (
            <li class="flex gap-x-2 text-nowrap">
              <Link href={SOCIAL.HREF} external aria-label={`${SITE.NAME} on ${SOCIAL.NAME}`}>
                {SOCIAL.NAME}
              </Link>
              {i < SOCIALS.length - 1 ? "/":""}
            </li>
          ))}
        </ul>
      </section>
    </div>
  </Container>
</PageLayout>

<script>
  const today = new Date();
  today.setHours(0, 0, 0, 0);

  document.querySelectorAll<HTMLUListElement>("[data-future-filter]").forEach((ul) => {
    const limit = ul.dataset.limit ? Number.parseInt(ul.dataset.limit) : 0;
    const items = [...ul.querySelectorAll<HTMLLIElement>(":scope > li[data-date]")];
    let shown = 0;

    items.forEach((li) => {
      const isFuture = new Date(li.dataset.date!) > today;
      const overLimit = limit > 0 && shown >= limit;
      li.hidden = isFuture || overLimit;
      if (!isFuture && !overLimit) shown++;
    });

    const seeAllId = ul.dataset.seeAll;
    if (seeAllId) {
      const published = items.filter((li) => new Date(li.dataset.date!) <= today).length;
      const el = document.getElementById(seeAllId);
      if (el) el.hidden = published <= limit;
    }
  });
</script>
