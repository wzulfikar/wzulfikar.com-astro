---
import { type CollectionEntry, getCollection } from "astro:content";
import ArrowCard from "@components/ArrowCard.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import Container from "@components/Container.astro";
import { POST } from "@consts";
import PageLayout from "@layouts/PageLayout.astro";

const data = (await getCollection("post"))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

type Acc = {
	[year: string]: CollectionEntry<"post">[];
};

const posts = data.reduce((acc: Acc, post) => {
	const year = post.data.date.getFullYear().toString();
	if (!acc[year]) {
		acc[year] = [];
	}
	acc[year].push(post);
	return acc;
}, {});

const years = Object.keys(posts).sort(
	(a, b) => Number.parseInt(b, 10) - Number.parseInt(a, 10),
);
---

<PageLayout title={POST.TITLE} description={POST.DESCRIPTION}>
  <Container>
    <div class="space-y-10">
      <Breadcrumb section="post" href="/post" />
      <div class="space-y-4">
        {years.map(year => (
          <section class="animate space-y-4" data-year-section>
            <div class="font-semibold text-black dark:text-white">
              {year}
            </div>
            <div>
              <ul class="flex flex-col gap-4">
                {
                  posts[year].map((post) => (
                    <li data-date={post.data.date.toISOString()}>
                      <ArrowCard entry={post}/>
                    </li>
                  ))
                }
              </ul>
            </div>
          </section>
        ))}
      </div>
    </div>
  </Container>
</PageLayout>

<script>
  const today = new Date();
  today.setHours(0, 0, 0, 0);

  document.querySelectorAll<HTMLLIElement>("li[data-date]").forEach((li) => {
    const postDate = new Date(li.dataset.date!);
    postDate.setHours(0, 0, 0, 0);
    if (postDate > today) li.hidden = true;
  });

  document.querySelectorAll<HTMLElement>("[data-year-section]").forEach((section) => {
    const items = section.querySelectorAll<HTMLLIElement>("li[data-date]");
    if ([...items].every((li) => li.hidden)) section.hidden = true;
  });
</script>
