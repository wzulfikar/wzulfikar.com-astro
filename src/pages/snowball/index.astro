---
import { type CollectionEntry, getCollection } from "astro:content";
import ArrowCard from "@components/ArrowCard.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import Container from "@components/Container.astro";
import { SNOWBALL } from "@consts";
import PageLayout from "@layouts/PageLayout.astro";

const data = (await getCollection("snowball"))
	.filter((entry) => !entry.data.draft)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

type Acc = {
	[year: string]: CollectionEntry<"snowball">[];
};

const entries = data.reduce((acc: Acc, entry) => {
	const year = entry.data.date.getFullYear().toString();
	if (!acc[year]) {
		acc[year] = [];
	}
	acc[year].push(entry);
	return acc;
}, {});

const years = Object.keys(entries).sort(
	(a, b) => Number.parseInt(b, 10) - Number.parseInt(a, 10),
);
---

<PageLayout title={SNOWBALL.TITLE} description={SNOWBALL.DESCRIPTION}>
  <Container>
    <div class="space-y-10">
      <Breadcrumb section="snowball" href="/snowball" />
      <div class="space-y-4">
        {years.map(year => (
          <section class="animate space-y-4" data-year-section>
            <div class="font-semibold text-black dark:text-white">
              {year}
            </div>
            <div>
              <ul class="flex flex-col gap-4">
                {entries[year].map((entry) => (
                  <li data-date={entry.data.date.toISOString()}>
                    <ArrowCard entry={entry} />
                  </li>
                ))}
              </ul>
            </div>
          </section>
        ))}
      </div>
    </div>
  </Container>
</PageLayout>

<script>
  const today = new Date();
  today.setHours(0, 0, 0, 0);

  document.querySelectorAll<HTMLLIElement>("li[data-date]").forEach((li) => {
    if (new Date(li.dataset.date!) > today) li.hidden = true;
  });

  document.querySelectorAll<HTMLElement>("[data-year-section]").forEach((section) => {
    const items = section.querySelectorAll<HTMLLIElement>("li[data-date]");
    if ([...items].every((li) => li.hidden)) section.hidden = true;
  });
</script>
